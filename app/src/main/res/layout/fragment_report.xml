<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/brand_background"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="近七日营养报告"
            android:textColor="@color/text_title"
            android:textSize="24sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="周期性宏量营养波动与良性生活轨迹映射"
            android:textColor="@color/text_caption"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiAnalysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/brand_primary_container"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvAiStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="💡 智能洞察(点击生成)"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp" />


                <TextView
                    android:id="@+id/tvAiAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    tools:text="您的热量摄入趋势整体呈良性平稳状态，蛋白质摄入配比十分优秀。请继续保持现在的轻盈节奏！"
                    android:textColor="@color/text_body"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="热量控制曲线 (kcal)"
            android:textColor="@color/text_title"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/brand_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/neutral_line"
            app:strokeWidth="1dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartCalories"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="蛋白质留存曲线 (g)"
            android:textColor="@color/text_title"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/brand_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/neutral_line"
            app:strokeWidth="1dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartProtein"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="脂肪留存曲线 (g)"
            android:textColor="@color/text_title"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/brand_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/neutral_line"
            app:strokeWidth="1dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartFat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium"
            android:text="碳水留存曲线 (g)"
            android:textColor="@color/text_title"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/brand_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/neutral_line"
            app:strokeWidth="1dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartCarbs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>