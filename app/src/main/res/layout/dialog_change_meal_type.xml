<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕒"
            android:textSize="36sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="调整餐别时段"
            android:textColor="@color/text_title"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvMealTypeDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重新规划此食物在今日时间轴上的归属"
            android:textColor="@color/text_caption"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"/>

        <RadioGroup
            android:id="@+id/rgMealTypeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbBreakfast"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌅  早餐"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbLunch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="☀️  午餐"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbDinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌙  晚餐"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbSnack"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌱  加餐 / 零食"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                app:useMaterialThemeColors="true" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealTypeCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="取消"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="23dp"
            android:textColor="@color/text_caption"
            app:strokeColor="@color/neutral_line"
            app:strokeWidth="1dp"
            app:rippleColor="@color/brand_primary_container" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>