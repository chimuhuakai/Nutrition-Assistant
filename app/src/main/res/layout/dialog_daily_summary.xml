<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 顶部区域：日期与记录条数胶囊 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvSummaryCountTag">

                <TextView
                    android:id="@+id/tvSummaryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_title"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="2026年05月28日" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当日膳食营养素全面盘点"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- 记录条数浅绿胶囊标签 -->
            <TextView
                android:id="@+id/tvSummaryCountTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textColor="@color/brand_primary_container"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_meal_tag"
                tools:text="共 5 条记录" />
        </RelativeLayout>

        <!-- 核心热量主视觉：采用浅翡翠绿容器承载，营造满载健康的成就感 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/brand_primary_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 当日摄入总热量"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:id="@+id/tvSummaryCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/brand_primary"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"
                        tools:text="1650" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" kcal"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 三大宏量营养素平铺横向网格 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp"
            android:weightSum="3">

            <!-- 蛋白质 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvSummaryProtein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_title"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="65 g" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="蛋白质"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 脂肪 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvSummaryFat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_title"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="45 g" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="脂肪"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 碳水 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvSummaryCarbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_title"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="210 g" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="碳水"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 底部高质感闭合胶囊大按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSummaryClose"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="知晓成果"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="25dp"
            android:backgroundTint="@color/brand_primary"
            android:textColor="@color/brand_surface"
            app:elevation="0dp"
            app:rippleColor="@color/brand_primary_container" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>