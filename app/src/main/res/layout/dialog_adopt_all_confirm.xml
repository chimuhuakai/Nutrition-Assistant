<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍱"
            android:textSize="44sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="一键采纳膳食计划"
            android:textColor="@color/text_title"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/dialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统将把本次推荐的所有美食菜品，依据默认餐别时段自动归档至您的饮食日记中，确定同步吗？"
            android:textColor="@color/text_caption"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="28dp"
            android:paddingHorizontal="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdoptCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="22dp"
                android:textColor="@color/text_caption"
                app:strokeColor="@color/neutral_line"
                app:strokeWidth="1dp"
                android:layout_marginEnd="8dp"
                app:rippleColor="@color/brand_primary_container" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdoptConfirm"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="确认采纳"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="22dp"
                android:backgroundTint="@color/brand_primary"
                android:textColor="@color/brand_surface"
                android:layout_marginStart="8dp"
                app:elevation="0dp"
                app:rippleColor="@color/brand_primary_container" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>