<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍃"
            android:textSize="44sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="淡忘这笔饮食记录？"
            android:textColor="@color/text_title"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvDeleteFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/brand_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:textColor="@color/brand_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="14dp"
            android:gravity="center"
            tools:text="全麦吐司面包" />

        <TextView
            android:id="@+id/dialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="移除该食物后，今日的已摄入热量及三大宏量营养素数据将会同步扣除。"
            android:textColor="@color/text_caption"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="28dp"
            android:paddingHorizontal="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="保留"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="22dp"
                android:textColor="@color/brand_primary"
                app:strokeColor="@color/brand_primary"
                app:strokeWidth="1dp"
                android:layout_marginEnd="8dp"
                app:rippleColor="@color/brand_primary_container" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="确定移除"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                app:cornerRadius="22dp"
                android:backgroundTint="@color/state_danger_container"
                android:textColor="@color/state_danger"
                android:layout_marginStart="8dp"
                app:elevation="0dp"
                app:rippleColor="#FCE8E6" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>