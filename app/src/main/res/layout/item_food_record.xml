<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/neutral_line"
    app:cardBackgroundColor="@color/brand_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="6dp"
            android:layout_height="24dp"
            android:background="@color/brand_primary"
            android:layout_marginRight="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                tools:text="食物名称"
                android:id="@+id/textFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_title"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                tools:text="营养信息"
                android:id="@+id/textNutrition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_caption"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- 餐别标签 -->
        <TextView
            android:id="@+id/textMealTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="加餐"
            android:textSize="11sp"
            android:textColor="@color/brand_surface"
            android:background="@drawable/bg_meal_tag"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginStart="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="淡忘"
            android:textColor="@color/text_caption"
            android:textSize="13sp"
            app:rippleColor="@color/state_danger_container" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>